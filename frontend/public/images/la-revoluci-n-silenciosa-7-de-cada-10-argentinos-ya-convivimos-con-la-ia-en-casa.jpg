		<style type="text/css" id="wp-custom-css">
			/*PROBLEMA FOTOS ACHICADAS MOVILES*/
@media (max-width: 767px){
	body.td-animation-stack-type0 .td-animation-stack .entry-thumb, body.td-animation-stack-type0 .post img:not(.woocommerce-product-gallery img):not(.rs-pzimg), body.td-animation-stack-type0 .td-animation-stack .td-lazy-img{
		width: 100%;
	}
}

/*OCULTOS*/
.ocultar {
	display:none;
}

/** Esta regla oculta ambos bloques por defecto con !important.
     * Es crucial para evitar un "parpadeo" (FOUC) al cargar la página.
     * JavaScript la eliminará después de inyectar las reglas correctas.*/
    .td_block_inicio_destacado,
    .td_block_footer_secundario {
        display: none;
        visibility: hidden;
    }

/*.menu-login-ocultar{
	display:none;
}*/
/*OCULTOS*/

/*ERROR VINOS JULIO*/
.td-animation-stack-type0-2:not(.woocommerce-product-gallery img){
	object-fit: contain;
}

/*MAGENES DE LAS GALERIAS*/
.imagen-vinos img{
	max-height: 500px;
}
@media (max-width: 767px){
	.imagen-vinos-nuevas figure{
		display: flex;
		justify-content: center;
		align-items: center;
	}
	.imagen-vinos-nuevas img{
	max-height: 300px !important;
	width: auto;
}
}
.tdi_97 .tdb-title-text{
	color: white !important;
}

/*BANNERS FIJOS*/
.convivimos-close-button{
	position: absolute !important;
	display: flex;
	justify-content: center;
	align-items: center; 
	font-family: Montserrat !important;
	background: #000 !important;
	color: white !important;
}

/*Error figure caption tagdiv*/
.tagdiv-type .alignnone{
	width: 100% !important;
}

/*Error figure caption tagdiv*/
/* verificar esto en los post al actualizar el tema. */

/*galeria texto a la izquierda*/
.wp-block-gallery.has-nested-images figure .wp-block-image figcaption {
        display: flex !important;
        flex-direction: column !important;
        text-align: left !important;
    }
.wp-block-gallery.has-nested-images figure.wp-block-image figcaption, .wp-block-gallery.has-nested-images figure.wp-block-image:has(figcaption):before{
	text-align: left !important;
}
.advads-window-size{
	display:none;
}

.td-more-articles-box{
	display: none;
}

.mensaje-rechazo-tarjeta{
	font-family: Roboto !important;
	color: #fd5000;
	border: solid 1px #fd5000 !important;
	padding: 10px !important;
	border-radius: 5px !important;
	margin-top: 10px !important;
}

.tenes-naranjax .wpforms-field-label{
	margin-bottom: 10px !important;
}

.tenes-naranjax-2{
	margin-bottom: 10px !important;
}

.tenes-naranjax-2 .wpforms-field-label{
	margin-bottom: 10px !important;
}

.su-row {
    display: flex !important;
    flex-wrap: wrap !important;
}
.su-column {
    margin-bottom: 0 !important;
}

.wp-block-media-text {
	display:flex;
}

/*banner viajes*/

.tdi_200 .td-module-thumb a:after {
    background: linear-gradient(
        to bottom, 
        rgb(53,104,183) 0%,    /* Inicia con el azul suave arriba */
        transparent 8%,             /* Se vuelve transparente al llegar al 10% */
        transparent 94%,             /* Se mantiene transparente hasta el 90% */
        rgb(53,104,183) 100%   /* Vuelve a ser azul fuerte al final (abajo) */
    ) !important; 
}

/*excerpt notas*/
.excerpt-code{
	font-family: Montserrat;
	font-style: italic;
	font-weight: bold;
	font-size: 15px;
}

/*SCROLL TO TOP*/
.td-js-loaded .td-scroll-up[data-style="style1"]{
	background: black;
	box-shadow: 0px 0px 5px rgba(255, 255, 255, 0.2);
}

.tdi_198 .td-module-thumb a:after {
	background: linear-gradient(180deg, rgba(53, 104, 183, 0.98), rgba(53, 104, 183, 0.0) 5%, rgba(53, 104, 183, 0.0) 95%, rgba(53, 104, 183, 0.98)) !important;
}

.botones-notas .tdi_140 .td-post-sharing-visible {
	position: fixed;
	z-index: 50 !important;
	bottom: 50px !important;
	left: 50px !important;
}
.botones-notas{
position: relative!important;
}

.td-post-sharing-visible, .td-social-sharing-hidden{
		display: flex !important;
	flex-direction: column !important;
}

 .td-social-expand-tabs{
	display: none !important;
}

/* Contenedor principal de los botones */
.td-post-sharing.tdb-block {
    position: fixed !important;
    bottom: 20px !important;    /* Distancia desde el fondo */
    left: 20px !important;      /* Distancia desde la izquierda */
    z-index: 9999 !important;   /* Asegura que esté por encima de otros elementos */
    background: transparent !important;
    margin: 0 !important;
    display: flex !important;
    flex-direction: column !important; /* Los apila verticalmente */
    width: auto !important;
}

/* Ajuste de los botones individuales */
.td-post-sharing.tdb-block .td-social-network {
    margin: 5px 0 !important;   /* Espacio entre botones */
    display: block !important;
}
@media (max-width: 600px){
	.botones-notas .td-post-sharing.tdb-block{
			bottom: 0px !important;
	left: 5px !important;
	}
	.td-social-network {
		margin-right: 15px !important;
	}
	.td-post-sharing-visible, .td-social-sharing-hidden{
	flex-direction: row !important;
}
}
/* Opcional: Ocultar el texto en móviles para que no estorbe */
@media (max-width: 767px) {
    .td-post-sharing.tdb-block .td-social-but-text {
        display: none !important;
    }
    .td-post-sharing.tdb-block .td-social-network, 
    .td-post-sharing.tdb-block .td-social-handler {
        width: 45px !important;
        min-width:40px !important;
    }
}
@media (max-width: 600px) {
	.tagdiv-type figure a{
		display: flex;
		justify-content: center;
		align-items: center;
	} 
	.tagdiv-type figure img{
		max-height: auto;
		width: 50%;
	}
	
	.excerpt-code{
		font-size: 14px;
	}
}
/*IMAGENES DE LAS GALERIAS*/
@media (max-width: 767px){
	.wp-block-gallery.has-nested-images figure.wp-block-image:not(#individual-image){
		width: calc(100% - var(--wp--style--unstable-gallery-gap, 16px)/2);
	}
	.wp-block-gallery.has-nested-images figure.wp-block-image figcaption{
		font-size: 10px;
	}
}		</style>
		
